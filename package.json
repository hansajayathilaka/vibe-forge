{
  "name": "vibe-forge",
  "version": "0.1.0",
  "private": true,
  "description": "Low-code platform template — fork to build data-driven apps with Claude Code",
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "dev": "concurrently --names \"pb,vite\" --prefix-colors \"blue,green\" \"cd backend && ./pocketbase serve --publicDir ../app\" \"pnpm --filter frontend dev\"",
    "build": "pnpm --filter frontend build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "tsc": "tsc -p frontend/tsconfig.json --noEmit && tsc -p shared/tsconfig.json --noEmit",
    "test": "pnpm --filter frontend test"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  }
}
